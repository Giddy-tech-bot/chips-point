# Environment Configuration

# Admin Panel
ADMIN_PASSWORD=admin123

# Daraja API (M-Pesa) Configuration
# Get these credentials from: https://developer.safaricom.co.ke/
# Sandbox: https://sandbox.safaricom.co.ke/
# Production: https://safaricom.co.ke/

# OAuth2 Credentials (from Daraja Dashboard)
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here

# M-Pesa Configuration
# Business Short Code: Your M-Pesa business till/paybill number (e.g., 174379 for Safaricom test)
DARAJA_BUSINESS_SHORT_CODE=174379

# Online Passkey: Generated from Daraja dashboard or ask Safaricom support
DARAJA_PASSKEY=your_passkey_here

# Callback URL: Where M-Pesa sends payment confirmations
# For production, use your live domain: https://yourdomain.com/api/payment-callback
# For testing: Use a tunneling service like ngrok
DARAJA_CALLBACK_URL=http://localhost:5000/api/payment-callback

# Environment: sandbox or production
NODE_ENV=development
